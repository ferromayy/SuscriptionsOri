# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (required in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only (optional for MVP health check; required for webhooks/admin jobs later)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated allowlist for Super Admin login (hardcoded bootstrap)
SUPER_ADMIN_EMAILS=admin@yourcompany.com

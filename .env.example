# PostgreSQL via Supabase (solo base de datos)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Super Admin bootstrap
SUPER_ADMIN_EMAIL=admin@yourcompany.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# URL base (links en emails e invitaciones)
# Local (.env.local): http://localhost:3000
# Vercel (Environment Variables): https://subscriptions-ori.vercel.app
#   o tu dominio: https://oricafe.com.ar
# Si no la definís en Vercel, se usa automáticamente https://<tu-proyecto>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mercado Pago (app de la plataforma Ori — OAuth para tenants)
# Creá una aplicación en https://www.mercadopago.com.ar/developers/panel
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/mercadopago/oauth/callback
# Webhook: {NEXT_PUBLIC_APP_URL}/api/mercadopago/webhook
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Opcional: clave para cifrar tokens (si no, se deriva de SUPABASE_SECRET_KEY)
# MP_TOKEN_ENCRYPTION_KEY=
# Para probar SUSCRIPCIONES con usuarios de prueba:
# dejá esto en false y conectá Pagos con el vendedor de prueba.
# (MP pide access_token "production" de la cuenta test, no test_token).
# MP_USE_TEST_TOKEN=false

# Emails (Resend — gratis 100/día) https://resend.com/api-keys
# Creá una API key en Resend y pegala acá (empieza con re_)
# En local, si no tenés key válida, el código se imprime en la consola del servidor.
RESEND_API_KEY=
EMAIL_FROM=Ori Cafe <noreply@oricafe.com.ar>

# Protege /api/cron/payment-cycles. Vercel la envía como Bearer automáticamente.
CRON_SECRET=
